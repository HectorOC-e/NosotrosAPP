# Supabase (public — safe in the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role — SERVER ONLY. Never prefix with NEXT_PUBLIC.
# Used by the AI mediator to read the Vault-stored API key.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: fixes the confirmation redirect origin.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
